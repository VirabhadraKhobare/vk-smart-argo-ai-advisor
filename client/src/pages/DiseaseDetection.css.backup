/* Responsive Design */
@media (max-width: 1024px) {
  .lg\:grid-cols-2 {
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }
}

@media (max-width: 640px) {
  .upload-zone-modern {
    padding: 1rem;
  }

  .upload-icon-modern {
    font-size: 2rem;
  }

  .text-2xl {
    font-size: 1.25rem;
  }

  .text-lg {
