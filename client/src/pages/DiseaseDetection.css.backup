/* Disease Detection Page Styles */

/* Modern Upload Zone Styling */
.upload-zone-modern {
  border: 2.5px dashed #e5e7eb;
  border-radius: 16px;
  padding: 2.5rem;
  text-align: center;
  cursor: pointer;
  transition: all 0.3s ease;
  background: linear-gradient(135deg, #f9fafb 0%, #ffffff 100%);
  position: relative;
  overflow: hidden;
}

.upload-zone-modern::before {
  content: "";
  position: absolute;
  top: -50%;
  right: -50%;
  width: 100%;
  height: 100%;
  background: radial-gradient(
    circle,
    rgba(34, 197, 94, 0.05) 0%,
    transparent 70%
  );
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.upload-zone-modern:hover {
  border-color: #22c55e;
  background: linear-gradient(135deg, #f0fdf4 0%, #ffffff 100%);
  box-shadow: 0 12px 32px rgba(34, 197, 94, 0.1);
}

.upload-zone-modern:hover::before {
  opacity: 1;
}

.upload-zone-active-modern {
  border-color: #22c55e;
  background: linear-gradient(135deg, #dcfce7 0%, #f0fdf4 100%);
  box-shadow: 0 16px 40px rgba(34, 197, 94, 0.15);
  transform: scale(1.02);
}

.upload-zone-active-modern::before {
  opacity: 1;
}

.upload-icon-modern {
  font-size: 3rem;
  color: #22c55e;
  margin-bottom: 0.75rem;
  animation: float-modern 3s ease-in-out infinite;
}

@keyframes float-modern {
  0%,
  100% {
    transform: translateY(0px);
  }
  50% {
    transform: translateY(-10px);
  }
}

/* Fade In Animation */
.animate-fade-in {
  animation: fadeIn 0.5s ease-in-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* Smooth transitions */
.grid {
  display: grid;
}

.grid-cols-1 {
  grid-template-columns: repeat(1, minmax(0, 1fr));
}

@media (min-width: 1024px) {
  .lg\:grid-cols-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

.gap-6 {
  gap: 1.5rem;
}

