# Smart Agro AI Advisor - Client Environment Variables
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to git (it's already in .gitignore)

# API Server URL (must include /api path and protocol)
# Local: http://localhost:5000/api
# Production backend (Render): https://your-render-service.onrender.com/api
# Use the Render service URL here, not the Vercel frontend URL.
REACT_APP_API_URL=https://vk-smart-argo-ai-advisor.onrender.com/api
